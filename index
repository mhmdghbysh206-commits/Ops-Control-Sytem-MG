    window.selectFlight = selectFlight;
    window.resetManualChecklist = resetManualChecklist;
    window.syncToCloud = syncToCloud;
    window.clearChecklist = clearChecklist;
    window.exportChecklistExcel = exportChecklistExcel;
    window.editFlight = editFlight;
    window.deleteFlight = deleteFlight;
    window.filterHistory = filterHistory;
    window.startTimer = startTimer;
    window.stopTimer = stopTimer;
    window.addFuel = addFuel;
    window.login = login;
    window.createUser = createUser;
    window.setTheme = setTheme;
    window.showPage = showPage;
