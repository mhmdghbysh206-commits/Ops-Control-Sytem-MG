                    if(sel) sel.value = d.items[n].status;
                    let note = document.getElementById(`n_${sid}`);
                    if(note) note.value = d.items[n].note;
                    updateItemStatus(sid);
                }
            });
            refreshAttachUI();
        }, 50);
        document.getElementById('activeFlightTitle').innerHTML = `<i class="fas fa-edit"></i> Editing: ${d.flight}`;
        showPage('dashboard', document.querySelector('.nav-link'));
    }
    async function deleteFlight(id) { if(confirm("Delete?")) await db.collection("flights_cloud").doc(id).delete(); showToast("Deleted","info"); }
    function filterHistory() { let term=document.getElementById('historyFilter').value.toLowerCase(); document.querySelectorAll('#historyBody tr').forEach(row=>row.style.display=row.innerText.toLowerCase().includes(term)?'':'none'); }

    // -------------------- NMA (INTEGRATED from NMA.html) --------------------
    let nmaProcessedData = [];

    function formatTimeNMA(val) {
        if (val === null || val === undefined || val === "" || String(val).toLowerCase() === "nan") return "";
        if (typeof val === 'number') {
            const date = XLSX.SSF.parse_date_code(val);
            return `${String(date.H).padStart(2,'0')}:${String(date.M).padStart(2,'0')}`;
        }
        const str = String(val).trim();
        if (str.includes(":")) {
            const parts = str.split(":");
            const h = parseInt(parts[0]);
            const m = parseInt(parts[1]);
            if (!isNaN(h) && !isNaN(m)) return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
        }
        return str;
    }

    function parseTimeToMinutesNMA(timeStr) {
        if (!timeStr) return null;
        const parts = timeStr.split(":");
        if (parts.length < 2) return null;
        return parseInt(parts[0]) * 60 + parseInt(parts[1]);
    }

    function getTimeDiffMinutesNMA(arr, dep) {
        if (!arr || !dep) return 9999;
        const arrMins = parseTimeToMinutesNMA(arr);
        const depMins = parseTimeToMinutesNMA(dep);
        if (arrMins === null || depMins === null) return 9999;
        let diff = depMins - arrMins;
        if (diff < 0) diff += 24 * 60;
        return diff;
    }

    function calculateGroundTimeStrNMA(arr, dep) {
        if (!arr || !dep) return "0:00:00";
        const mins = getTimeDiffMinutesNMA(arr, dep);
        if (mins === 9999) return "0:00:00";
        const hours = Math.floor(mins / 60);
        const minutes = mins % 60;
        return `${hours}:${String(minutes).padStart(2,'0')}:00`;
    }

    function processNMAExcel(workbook) {
        const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
        const rawData = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });
        if (rawData.length < 3) return [];

        const row1 = rawData[1] || [];
        const aircraftInfo = [];
        for (let i = 0; i < row1.length; i++) {
            const val = String(row1[i] || "");
            if (val.includes("Seat:")) {
                const reg = val.split(" ")[0].trim();
                aircraftInfo.push({ col: i, reg: reg });
            }
        }
        if (aircraftInfo.length === 0) return [];

        const allFlights = [];
        let currentDate = null;

        for (let rowIdx = 2; rowIdx < rawData.length; rowIdx++) {
            const row = rawData[rowIdx];
            if (!row) continue;
            const firstCell = String(row[0] || "").trim();
            const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            const dayNames = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
            const hasMonth = monthNames.some(m => firstCell.includes(m));
            const hasDay = dayNames.some(d => firstCell.includes(d));
            if (hasMonth && hasDay) currentDate = firstCell;
            if (!currentDate) continue;

            for (let ac of aircraftInfo) {
                const startCol = ac.col;
                const fNo = String(row[startCol] || "").trim();
                if (fNo === "" || fNo === "nan" || fNo === "NaN") continue;
                const orig = String(row[startCol+1] || "").trim();
                const dest = String(row[startCol+2] || "").trim();
                const depTime = formatTimeNMA(row[startCol+3]);
                const arrTime = formatTimeNMA(row[startCol+4]);
                const acType = String(row[startCol+5] || "").trim();
                const remark = String(row[startCol+6] || "").trim();
                if (orig.includes("CAI") || dest.includes("CAI") || remark.includes("CAI")) {
                    allFlights.push({
                        date: currentDate, reg: ac.reg, flightNo: fNo, origin: orig, dest: dest,
                        dep: depTime, arr: arrTime, type: acType, remark: remark === "nan" ? "" : remark, rowIdx: rowIdx
                    });
                }
            }
        }
        if (allFlights.length === 0) return [];

        const datesOrder = [...new Set(allFlights.map(f => f.date))];
        const finalRows = [];

        for (let d of datesOrder) {
            const dayFlights = allFlights.filter(f => f.date === d);
            const regs = [...new Set(dayFlights.map(f => f.reg))];
            const dayOutput = [];
            for (let r of regs) {
                let regFlights = dayFlights.filter(f => f.reg === r).sort((a,b) => a.rowIdx - b.rowIdx);
                let i = 0;
                while (i < regFlights.length) {
                    const f = regFlights[i];
                    let combined = false;
                    if (f.dest.includes("CAI") && i+1 < regFlights.length) {
                        const fNext = regFlights[i+1];
                        if (fNext.origin.includes("CAI")) {
                            const waitTime = getTimeDiffMinutesNMA(f.arr, fNext.dep);
                            if (waitTime <= 150) {
                                const remarkCombined = (f.remark + " " + fNext.remark).replace(/nan/gi, "").trim();
                                dayOutput.push({
                                    Date: d, Arln: "NMA", FlightNo: `${f.flightNo}/${fNext.flightNo}`,
                                    ACType: f.type, Reg: r, ARR: f.arr, DEP: fNext.dep,
                                    GroundTime: calculateGroundTimeStrNMA(f.arr, fNext.dep),
                                    Route: `${f.origin}/CAI/${fNext.dest}`, Hndlng: "TA", Remarks: remarkCombined
                                });
                                combined = true;
                                i += 2;
                            }
                        }
                    }
                    if (!combined) {
                        if (f.dest.includes("CAI")) {
                            dayOutput.push({
                                Date: d, Arln: "NMA", FlightNo: f.flightNo, ACType: f.type, Reg: r,
                                ARR: f.arr, DEP: "", GroundTime: "0:00:00",
                                Route: `${f.origin}/CAI`, Hndlng: "AH", Remarks: f.remark.replace(/nan/gi, "").trim()
                            });
                        } else {
                            dayOutput.push({
                                Date: d, Arln: "NMA", FlightNo: f.flightNo, ACType: f.type, Reg: r,
                                ARR: "", DEP: f.dep, GroundTime: "0:00:00",
                                Route: `CAI/${f.dest}`, Hndlng: "DH", Remarks: f.remark.replace(/nan/gi, "").trim()
                            });
                        }
                        i += 1;
                    }
                }
            }
            dayOutput.sort((a,b) => (a.DEP || a.ARR || "99:99").localeCompare(b.DEP || b.ARR || "99:99"));
            finalRows.push(...dayOutput);
        }
        return finalRows;
    }

    function renderNMAData(data) {
        const tbody = document.getElementById('nmaTableBody');
        const tableContainer = document.getElementById('nmaTableContainer');
        const emptyState = document.getElementById('nmaEmptyState');
        const statsBar = document.getElementById('nmaStatsBar');
        const recordCount = document.getElementById('nmaRecordCount');
        if (!data || data.length === 0) {
            tableContainer.style.display = 'none';
            statsBar.style.display = 'none';
            emptyState.style.display = 'block';
            emptyState.innerHTML = '<div class="empty-state">â ï¸ No CAI-related flights found</div>';
            return;
        }
        emptyState.style.display = 'none';
        tableContainer.style.display = 'block';
        statsBar.style.display = 'flex';
        recordCount.textContent = data.length + ' Flights';
        let html = '';
        data.forEach((row, idx) => {
            const remarkClass = /NEW|DIV|\/EQT/i.test(row.Remarks) ? 'remark-highlight' : '';
            html += `<tr>
                <td>${idx+1}</td><td>${row.Date || ''}</td><td>${row.Arln || ''}</td><td>${row.FlightNo || ''}</td>
                <td>${row.ACType || ''}</td><td>${row.Reg || ''}</td><td>${row.ARR || ''}</td><td>${row.DEP || ''}</td>
                <td>${row.GroundTime || ''}</td><td>${row.Route || ''}</td><td>${row.Hndlng || ''}</td>
                <td class="${remarkClass}">${row.Remarks || ''}</td>
            </tr>`;
        });
        tbody.innerHTML = html;
    }

    function exportNMAExcel() {
        if (!nmaProcessedData.length) { showToast("No data to export"); return; }
        const headers = ["NR","Date","Arln","Flight#","A/C Type","Reg","ARR","DEP","GRND TIME","Route","Hndlng","REMARKS"];
        const rows = nmaProcessedData.map((row, idx) => [
            idx+1, row.Date, row.Arln, row.FlightNo, row.ACType, row.Reg,
            row.ARR, row.DEP, row.GroundTime, row.Route, row.Hndlng, row.Remarks
        ]);
        const wsData = [headers, ...rows];
        const ws = XLSX.utils.aoa_to_sheet(wsData);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Cairo Schedule");
        const dateStr = new Date().toISOString().slice(0,10);
        XLSX.writeFile(wb, `NMA_Cairo_Schedule_${dateStr}.xlsx`);
        showToast("â Excel file downloaded successfully!");
    }

    function handleNMAFile(file) {
        if (!file) return;
        const emptyState = document.getElementById('nmaEmptyState');
        emptyState.style.display = 'block';
        emptyState.innerHTML = '<div class="empty-state"><span class="loading"></span> Processing file...</div>';
        const reader = new FileReader();
        reader.onload = (e) => {
            try {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, { type: 'array' });
                setTimeout(() => {
                    nmaProcessedData = processNMAExcel(workbook);
                    renderNMAData(nmaProcessedData);
                    if (nmaProcessedData.length) showToast(`â Extracted ${nmaProcessedData.length} flights`);
                }, 10);
            } catch(err) {
                emptyState.innerHTML = '<div class="empty-state">â Error reading file. Ensure it is a valid Excel file.</div>';
                showToast("Failed to process file");
            }
        };
        reader.readAsArrayBuffer(file);
    }

    // NMA UI events
    const nmaDropZone = document.getElementById('nmaDropZone');
    const nmaFileInput = document.getElementById('nmaFileInput');
    const nmaSelectBtn = document.getElementById('nmaSelectBtn');
    const nmaDownloadBtn = document.getElementById('nmaDownloadBtn');
    if (nmaSelectBtn) {
        nmaSelectBtn.addEventListener('click', () => nmaFileInput.click());
        nmaFileInput.addEventListener('change', (e) => { if(e.target.files[0]) handleNMAFile(e.target.files[0]); nmaFileInput.value = ''; });
        nmaDropZone.addEventListener('click', (e) => { if(e.target !== nmaSelectBtn && !e.target.closest('#nmaSelectBtn')) nmaFileInput.click(); });
        nmaDropZone.addEventListener('dragover', (e) => { e.preventDefault(); nmaDropZone.style.borderColor = 'var(--accent)'; });
        nmaDropZone.addEventListener('dragleave', () => { nmaDropZone.style.borderColor = 'var(--border)'; });
        nmaDropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            nmaDropZone.style.borderColor = 'var(--border)';
            const file = e.dataTransfer.files[0];
            if (file && (file.name.endsWith('.xlsx') || file.name.endsWith('.xls'))) handleNMAFile(file);
            else showToast("Please drop an Excel file (.xlsx/.xls)");
        });
        nmaDownloadBtn.addEventListener('click', exportNMAExcel);
    }

    // -------------------- TOOLS --------------------
    function startTimer() { if(timerInterval) clearInterval(timerInterval); timerInterval = setInterval(() => { timerSeconds++; let h=Math.floor(timerSeconds/3600),m=Math.floor((timerSeconds%3600)/60),s=timerSeconds%60; document.getElementById('timerDisplay').innerText = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`; },1000); }
    function stopTimer() { if(timerInterval) { clearInterval(timerInterval); timerInterval = null; showToast("Timer stopped","info"); } }
