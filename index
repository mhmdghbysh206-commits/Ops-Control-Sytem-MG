    function showPage(id,btn) { document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.querySelectorAll('.nav-link').forEach(l=>l.classList.remove('active')); document.getElementById(id).classList.add('active'); btn.classList.add('active'); }
    function setTheme(t) { document.documentElement.setAttribute('data-theme', t); localStorage.setItem('ops_theme', t); showToast(`Theme: ${t}`, "info"); }
