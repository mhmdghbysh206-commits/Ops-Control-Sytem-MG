<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>OPS VORTEX | Integrated NMA</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.1.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.1.1/firebase-firestore-compat.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', system-ui; }
        :root {
            --bg: #0b1120; --card: #0f172acc; --border: #ffffff20; --accent: #3b82f6;
            --success: #10b981; --danger: #ef4444; --text: #f1f5f9;
        }
        [data-theme="light"] { --bg: #e2e8f0; --card: #ffffffcc; --text: #0f172a; --border: #00000020; }
        [data-theme="midnight"] { --bg: #000000; --accent: #f59e0b; --text: #fffbeb; }
        body { background: var(--bg); color: var(--text); transition: 0.2s; }
        .top-nav { background: var(--card); backdrop-filter: blur(12px); display: flex; justify-content: center; gap: 0.5rem; padding: 1rem; position: sticky; top: 0; z-index: 100; flex-wrap: wrap; }
        .nav-link { padding: 0.5rem 1.2rem; border-radius: 2rem; cursor: pointer; font-weight: bold; }
        .nav-link.active { background: var(--accent); color: white; }
        .container { max-width: 1400px; margin: 1.5rem auto; padding: 0 1rem; }
        .glass-card { background: var(--card); backdrop-filter: blur(8px); border-radius: 1.5rem; border: 1px solid var(--border); padding: 1.5rem; margin-bottom: 1.5rem; }
        .page { display: none; animation: fade 0.2s; }
        .page.active { display: block; }
        @keyframes fade { from { opacity: 0; } to { opacity: 1; } }
        h2 { font-size: 1.6rem; margin-bottom: 1rem; }
        .btn-primary, .btn-secondary { border: none; padding: 0.6rem 1.2rem; border-radius: 2rem; font-weight: bold; cursor: pointer; margin: 0.2rem; }
        .btn-primary { background: var(--accent); color: white; }
        .btn-secondary { background: #334155; color: white; }
        input, select, textarea { width: 100%; padding: 0.6rem; background: #00000030; border: 1px solid var(--border); border-radius: 1rem; color: var(--text); margin-bottom: 0.5rem; }
        .items-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 0.8rem; margin-top: 1rem; }
        .item-card { background: #00000020; border-radius: 1rem; padding: 0.6rem; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; border-left: 4px solid var(--danger); }
        .status-done { border-left-color: var(--success); background: #10b98110; }
        .progress-bar { height: 6px; background: #334155; border-radius: 4px; overflow: hidden; margin: 0.5rem 0; }
        .progress-fill { height: 100%; width: 0%; background: var(--success); }
        table { width: 100%; border-collapse: collapse; background: #00000020; border-radius: 1rem; overflow: auto; display: block; }
        th, td { padding: 0.5rem; border-bottom: 1px solid var(--border); text-align: center; }
        th { background: var(--accent); }
        .toast { position: fixed; bottom: 20px; right: 20px; background: var(--card); backdrop-filter: blur(12px); padding: 0.7rem 1.2rem; border-radius: 2rem; border-left: 3px solid var(--accent); z-index: 1000; }
        #loginOverlay { position: fixed; inset: 0; background: var(--bg); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .login-box { background: var(--card); padding: 2rem; border-radius: 2rem; width: 320px; text-align: center; }
        .attach-list { font-size: 0.7rem; display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.3rem; grid-column: 1/-1; }
        .modal { position: fixed; inset: 0; background: #000000cc; backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
        .modal-content { background: var(--card); border-radius: 1.5rem; padding: 1.5rem; max-width: 500px; width: 90%; }
        @media (max-width: 700px) { .items-grid { grid-template-columns: 1fr; } }
        .upload-area { border: 2px dashed var(--border); border-radius: 1.5rem; padding: 1.5rem; text-align: center; cursor: pointer; transition: 0.2s; margin-bottom: 1rem; }
        .upload-area:hover { border-color: var(--accent); background: rgba(59,130,246,0.1); }
        .stats-bar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 1rem; }
        .badge { background: var(--accent); padding: 0.3rem 1rem; border-radius: 2rem; font-size: 0.8rem; }
    </style>
</head>
<body>
<div id="loginOverlay">
    <div class="login-box">
        <i class="fas fa-bolt" style="font-size: 3rem; color: var(--accent);"></i>
        <h1>OPS VORTEX</h1>
        <input type="text" id="username" placeholder="Username">
        <input type="password" id="password" placeholder="Password">
        <button class="btn-primary" style="width:100%" onclick="login()">LOGIN</button>
    </div>
</div>

<div id="mainApp" style="display:none;">
    <div class="top-nav">
        <div class="nav-link active" onclick="showPage('dashboard',this)"><i class="fas fa-clipboard-list"></i> Checklist</div>
        <div class="nav-link" onclick="showPage('nma',this)"><i class="fas fa-chart-line"></i> NMA</div>
        <div class="nav-link" onclick="showPage('history',this)"><i class="fas fa-history"></i> Cloud Log</div>
        <div class="nav-link" onclick="showPage('tools',this)"><i class="fas fa-tools"></i> Tools</div>
        <div class="nav-link" onclick="showPage('settings',this)"><i class="fas fa-cog"></i> Settings</div>
    </div>
    <div class="container">
        <!-- CHECKLIST PAGE (fully functional) -->
        <div id="dashboard" class="page active glass-card">
            <div style="display: flex; justify-content: space-between; flex-wrap: wrap;">
                <h2><i class="fas fa-clipboard-list"></i> Flight Checklist | <span id="opLabel"></span></h2>
                <div>
                    <button class="btn-secondary" onclick="exportChecklistExcel()"><i class="fas fa-file-excel"></i> Export Excel</button>
                    <button class="btn-secondary" onclick="resetManualChecklist()"><i class="fas fa-plus"></i> New Manual</button>
                </div>
            </div>
            <textarea id="rawInput" placeholder="Paste flight data (e.g., NE200 9K-CAN CAI/KWI DH 08:00 10:35)" rows="2"></textarea>
            <button class="btn-primary" onclick="parseFlights()">Analyze Flights</button>
            <div id="flightList" style="display:none; margin-top:1rem; overflow-x:auto;">
                <h3>Detected Flights</h3>
                <table><thead><tr><th>Flight</th><th>Reg</th><th>Type</th><th>Arrival</th><th>Departure</th><th></th></tr></thead><tbody id="flightsBody"></tbody></table>
            </div>
            <div id="checklistArea" style="display:none; margin-top:1.5rem;">
                <h3 id="activeFlightTitle"></h3>
                <div class="progress-bar"><div class="progress-fill" id="progFill"></div></div>
                <input type="hidden" id="editDocId">
                <div class="items-grid" id="checklistContainer"></div>
                <div style="display:flex; gap:1rem; margin-top:1rem;">
                    <button class="btn-primary" style="background:var(--success); flex:1" onclick="syncToCloud()">Save to Cloud</button>
                    <button class="btn-secondary" onclick="clearChecklist()">Clear</button>
                </div>
            </div>
        </div>

        <!-- NMA PAGE (INTEGRATED WORKING VERSION FROM NMA.html) -->
        <div id="nma" class="page glass-card">
            <h2><i class="fas fa-chart-line"></i> NMA Cairo Schedule</h2>
            <div class="upload-area" id="nmaDropZone">
                <i class="fas fa-cloud-upload-alt" style="font-size: 2rem;"></i>
                <div>Choose Excel File or Drag & Drop</div>
                <div style="font-size:0.8rem; opacity:0.7;">File must be in the same format as SCHEDULE_FILE.xlsx</div>
                <input type="file" id="nmaFileInput" accept=".xlsx, .xls" style="display:none;">
                <button class="btn-secondary" id="nmaSelectBtn" style="margin-top:10px;">Browse Files</button>
            </div>
            <div id="nmaStatsBar" class="stats-bar" style="display:none;">
                <div><span class="badge" id="nmaRecordCount">0 Flights</span></div>
                <button class="btn-primary" id="nmaDownloadBtn">â¬ï¸ Download Processed Excel</button>
            </div>
            <div id="nmaTableContainer" style="overflow-x:auto; display:none;">
                <table id="nmaResultTable">
                    <thead><tr><th>#</th><th>Date</th><th>Airline</th><th>Flight #</th><th>A/C Type</th><th>Reg</th><th>ARR</th><th>DEP</th><th>Ground Time</th><th>Route</th><th>Handling</th><th>Remarks</th></tr></thead>
                    <tbody id="nmaTableBody"></tbody>
                </table>
            </div>
            <div id="nmaEmptyState" class="empty-state" style="text-align:center; padding:2rem;">â³ Waiting for schedule file...</div>
        </div>

        <!-- CLOUD HISTORY -->
        <div id="history" class="page glass-card">
            <h2>Cloud Operations Log</h2>
            <input type="text" id="historyFilter" placeholder="Search..." onkeyup="filterHistory()">
            <div style="overflow-x:auto;"><table><thead><tr><th>Date</th><th>Flight</th><th>Type</th><th>Status</th><th>User</th><th>Actions</th></tr></thead><tbody id="historyBody"></tbody></table></div>
        </div>

        <!-- TOOLS -->
        <div id="tools" class="page glass-card">
            <h2>Field Tools</h2>
            <button class="btn-secondary" onclick="startTimer()">Start Timer</button> <span id="timerDisplay">00:00:00</span> <button class="btn-secondary" onclick="stopTimer()">Stop</button><br>
            <input type="number" id="fuelQty" placeholder="Fuel (L)"><button class="btn-primary" onclick="addFuel()">Record</button>
            <ul id="fuelList"></ul>
        </div>

        <!-- SETTINGS -->
        <div id="settings" class="page glass-card">
            <h2>Settings</h2>
            <button class="btn-secondary" onclick="setTheme('light')">Light</button>
            <button class="btn-secondary" onclick="setTheme('dark')">Dark</button>
            <button class="btn-secondary" onclick="setTheme('midnight')">Midnight</button>
            <div id="adminPanel" style="display:none; margin-top:1rem;"><h3>Admin</h3><input id="newUser" placeholder="Username"><input id="newPass" type="password" placeholder="Password"><button class="btn-primary" onclick="createUser()">Create/Update</button><div id="userList"></div></div>
        </div>
    </div>
</div>

<script>
    // -------------------- FIREBASE (unchanged) --------------------
    const firebaseConfig = {
        apiKey: "AIzaSyAMs5A2t0tx_q1U_CUtS4NbMP2ELfEozXw",
        authDomain: "ops-system-pro.firebaseapp.com",
        projectId: "ops-system-pro",
        storageBucket: "ops-system-pro.appspot.com",
        appId: "1:197480388481:web:66aacf19a6ba4878897a80"
    };
    let db = null;
    try { firebase.initializeApp(firebaseConfig); db = firebase.firestore(); } catch(e) { console.warn(e); }

    let currentUser = "";
    let activeFlight = { flight: "MANUAL", reg: "N/A", type: "---", airline: "CUSTOM", arrTime: "", depTime: "" };
    let attachments = {};
    let editingDocId = null;
    let timerInterval = null, timerSeconds = 0;

    // Checklist items
    const allItems = ["Fuel","Catering","Transfer","FPL Check","HOTAC","VIP Lounge","Visa",
        "Explosive Trace Detection","Disinfection Spray Cans","Operation Hall Name","GSC",
        "ZAS Involvement","POCs","Weather Folder","GDs / PNLs","Pax In & Pax Out","MIA",
        "G.I.S","National Security","Ports Security","Immigration","Operations Sector","Russian Committee"];
    function cleanId(str) { return str.replace(/[^a-z0-9]/gi, '').toLowerCase(); }

    // -------------------- CHECKLIST UI (full functional) --------------------
    function buildChecklist() {
        const container = document.getElementById('checklistContainer');
        if (!container) return;
        container.innerHTML = "";
        const groups = {
            "Flight Safety": ["Fuel","FPL Check","Weather Folder","GDs / PNLs"],
            "Logistics": ["Catering","Transfer","HOTAC","VIP Lounge","Disinfection Spray Cans","Operation Hall Name"],
            "Security": ["Explosive Trace Detection","National Security","Ports Security","Immigration","Russian Committee","ZAS Involvement"],
            "Administration": ["Visa","GSC","POCs","Pax In & Pax Out","MIA","G.I.S","Operations Sector"]
        };
        for (let [cat, items] of Object.entries(groups)) {
            let catDiv = document.createElement('div');
            catDiv.style.gridColumn = "1/-1";
            catDiv.style.marginTop = "10px";
            catDiv.style.fontWeight = "bold";
            catDiv.innerHTML = `<i class="fas fa-folder-open"></i> ${cat}`;
            container.appendChild(catDiv);
            items.forEach(name => {
                const id = cleanId(name);
                const card = document.createElement('div');
                card.className = "item-card";
                card.id = `card_${id}`;
                card.innerHTML = `
                    <label style="min-width:100px;">${name}</label>
                    <select id="s_${id}" onchange="updateItemStatus('${id}')">
                        <option value="Pending">â³ Pending</option>
                        <option value="Done">â Done</option>
                    </select>
                    <input id="n_${id}" placeholder="Notes" style="flex:1;">
                    <button class="btn-secondary" style="padding:4px 8px;" onclick="openAttach('${id}','${name}')"><i class="fas fa-paperclip"></i></button>
                `;
                container.appendChild(card);
                const attachDiv = document.createElement('div');
                attachDiv.id = `attachList_${id}`;
                attachDiv.className = "attach-list";
                container.appendChild(attachDiv);
            });
        }
        loadDraft();
        updateProgress();
    }
    function updateItemStatus(id) {
        let sel = document.getElementById(`s_${id}`);
        if(sel) {
            document.getElementById(`card_${id}`).className = `item-card ${sel.value === 'Done' ? 'status-done' : ''}`;
            updateProgress();
            saveDraft();
        }
    }
    function updateProgress() {
        let done = allItems.filter(n => document.getElementById(`s_${cleanId(n)}`)?.value === "Done").length;
        let percent = (done/allItems.length)*100;
        let fill = document.getElementById('progFill');
        if(fill) fill.style.width = percent + "%";
    }
    function saveDraft() {
        if(!activeFlight.flight) return;
        let draft = { flight: activeFlight, items: {}, attachments };
        allItems.forEach(n => {
            let id = cleanId(n);
            draft.items[n] = {
                status: document.getElementById(`s_${id}`)?.value || "Pending",
                note: document.getElementById(`n_${id}`)?.value || ""
            };
        });
        localStorage.setItem(`draft_${activeFlight.flight}`, JSON.stringify(draft));
    }
    function loadDraft() {
        let key = `draft_${activeFlight.flight}`;
        let saved = localStorage.getItem(key);
        if(saved) {
            let data = JSON.parse(saved);
            if(data.flight) activeFlight = data.flight;
            attachments = data.attachments || {};
            allItems.forEach(n => {
                let id = cleanId(n);
                if(data.items && data.items[n]) {
                    let sel = document.getElementById(`s_${id}`);
                    if(sel) sel.value = data.items[n].status;
                    let note = document.getElementById(`n_${id}`);
                    if(note) note.value = data.items[n].note;
                    updateItemStatus(id);
                }
            });
            refreshAttachUI();
        } else attachments = {};
    }
    function refreshAttachUI() {
        allItems.forEach(n => {
            let id = cleanId(n);
            let cont = document.getElementById(`attachList_${id}`);
            if(cont) {
                let files = attachments[id] || [];
                cont.innerHTML = files.length ? files.map(f => `<a href="${f.url}" target="_blank" download="${f.name}">ð ${f.name}</a>`).join(" | ") : "";
            }
        });
    }
    let currentAttachId = null;
    function openAttach(itemId, itemName) {
        currentAttachId = itemId;
        let files = attachments[itemId] || [];
        let listHtml = files.map((f,idx) => `<li>${f.name} <button onclick="removeAttach('${itemId}',${idx})">â</button></li>`).join('');
        let modal = document.createElement('div');
        modal.className = 'modal';
        modal.id = 'attachModal';
        modal.innerHTML = `<div class="modal-content"><h3>Attachments: ${itemName}</h3><input type="file" id="attachInput" multiple><button class="btn-primary" onclick="uploadAttach()">Upload</button><ul>${listHtml||'<li>No attachments</li>'}</ul><button class="btn-secondary" onclick="closeModal()">Close</button></div>`;
        document.body.appendChild(modal);
    }
    function closeModal() { document.getElementById('attachModal')?.remove(); }
    function uploadAttach() {
        let input = document.getElementById('attachInput');
        if(!input.files.length) return;
        let files = Array.from(input.files);
        let itemId = currentAttachId;
        if(!attachments[itemId]) attachments[itemId] = [];
        files.forEach(file => {
            let reader = new FileReader();
            reader.onload = e => {
                attachments[itemId].push({ name: file.name, url: e.target.result, timestamp: Date.now() });
                saveDraft();
                refreshAttachUI();
                closeModal();
                showToast(`Uploaded ${file.name}`, "success");
            };
            reader.readAsDataURL(file);
        });
    }
    function removeAttach(itemId, idx) {
        if(confirm("Delete?")) {
            attachments[itemId].splice(idx,1);
            if(attachments[itemId].length===0) delete attachments[itemId];
            saveDraft();
            refreshAttachUI();
            closeModal();
            openAttach(itemId, "");
        }
    }
    async function syncToCloud() {
        if(!db) { showToast("Firebase not available, saved locally", "warning"); saveDraft(); return; }
        if(!activeFlight.flight) activeFlight.flight = "MANUAL_"+Date.now();
        let itemsData = {};
        allItems.forEach(n => {
            let id = cleanId(n);
            itemsData[n] = {
                status: document.getElementById(`s_${id}`)?.value || "Pending",
                note: document.getElementById(`n_${id}`)?.value || "",
                attachments: attachments[id] || []
            };
        });
        let allDone = Object.values(itemsData).every(i => i.status === "Done");
        let flightData = {
            flight: activeFlight.flight, reg: activeFlight.reg, type: activeFlight.type, airline: activeFlight.airline,
            arrTime: activeFlight.arrTime, depTime: activeFlight.depTime,
            items: itemsData, allDone, user: currentUser,
            timestamp: new Date().toLocaleString(),
            serverTime: firebase.firestore.FieldValue.serverTimestamp()
        };
        try {
            if(editingDocId) await db.collection("flights_cloud").doc(editingDocId).set(flightData);
            else await db.collection("flights_cloud").add(flightData);
            showToast("Saved to cloud â", "success");
            clearChecklist();
        } catch(e) { showToast("Cloud error, saved locally", "danger"); saveDraft(); }
    }
    function exportChecklistExcel() {
        if(!activeFlight.flight) { showToast("No active flight", "warning"); return; }
        let rows = [["Flight Number", activeFlight.flight], ["Registration", activeFlight.reg], ["Type", activeFlight.type], ["Arrival", activeFlight.arrTime], ["Departure", activeFlight.depTime], [], ["Item","Status","Notes","Attachments"]];
        allItems.forEach(n => {
            let id = cleanId(n);
            rows.push([n, document.getElementById(`s_${id}`)?.value, document.getElementById(`n_${id}`)?.value, (attachments[id]||[]).map(a=>a.url).join("; ")]);
        });
        let ws = XLSX.utils.aoa_to_sheet(rows);
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Checklist");
        XLSX.writeFile(wb, `Checklist_${activeFlight.flight}.xlsx`);
        showToast("Excel exported", "success");
    }
    function parseFlights() {
        let text = document.getElementById('rawInput').value.toUpperCase();
        let tbody = document.getElementById('flightsBody');
        tbody.innerHTML = "";
        text.split('\n').forEach(line => {
            if(line.trim().length<5) return;
            let flight = (line.match(/[A-Z0-9]{2,4}\s?\d{2,5}/)||["UNK"])[0];
            let reg = (line.match(/[A-Z0-9]{2,5}-[A-Z0-9]{2,5}/)||["TBA"])[0];
            let type = line.includes("TA")?"TA":(line.includes("AH")?"AH":"DH");
            let times = line.match(/\b\d{2}:\d{2}\b/g)||[];
            let arr="", dep="";
            if(times.length>=2) { dep=times[0]; arr=times[1]; }
            else if(times.length===1) { if(type==="AH") arr=times[0]; else dep=times[0]; }
            tbody.innerHTML += `<tr><td>${flight}</td><td>${reg}</td><td>${type}</td><td>${arr||'--:--'}</td><td>${dep||'--:--'}</td><td><button class="btn-secondary" onclick="selectFlight('${flight}','${reg}','${type}','${arr}','${dep}')">Select</button></td></tr>`;
        });
        document.getElementById('flightList').style.display = 'block';
    }
    function selectFlight(flt,reg,type,arr,dep) {
        activeFlight = { flight: flt, reg, type, airline: "NMA", arrTime: arr, depTime: dep };
        editingDocId = null;
        document.getElementById('checklistArea').style.display = 'block';
        document.getElementById('activeFlightTitle').innerHTML = `<i class="fas fa-rocket"></i> Flight: ${flt} (${reg}) | ${type} | Arr ${arr} Dep ${dep}`;
        buildChecklist();
        window.scrollTo({ top: document.getElementById('checklistArea').offsetTop-80, behavior: 'smooth' });
    }
    function resetManualChecklist() {
        activeFlight = { flight: "MANUAL_"+Date.now(), reg: "N/A", type: "---", airline: "CUSTOM", arrTime: "", depTime: "" };
        editingDocId = null;
        attachments = {};
        document.getElementById('checklistArea').style.display = 'block';
        document.getElementById('activeFlightTitle').innerHTML = `<i class="fas fa-pen-alt"></i> Manual Checklist`;
        buildChecklist();
    }
    function clearChecklist() {
        document.getElementById('checklistArea').style.display = 'none';
        document.getElementById('editDocId').value = "";
        attachments = {};
        activeFlight = { flight: "MANUAL", reg: "N/A", type: "---", airline: "CUSTOM", arrTime: "", depTime: "" };
    }
    function loadHistory() {
        if(!db) return;
        db.collection("flights_cloud").orderBy("serverTime","desc").limit(50).onSnapshot(snap => {
            let tbody = document.getElementById('historyBody');
            tbody.innerHTML = "";
            snap.forEach(doc => {
                let d = doc.data();
                let del = (currentUser==='admin') ? `<button onclick="deleteFlight('${doc.id}')" style="background:#e11d48; border:none; border-radius:1rem; padding:4px 8px;">ðï¸</button>` : '';
                tbody.innerHTML += `<tr><td>${d.timestamp||"â"}</td><td><b>${d.flight}</b> (${d.reg})</td><td>${d.type}</td><td style="color:${d.allDone?'#10b981':'#f97316'}">${d.allDone?'COMPLETE':'PENDING'}</td><td>${d.user}</td><td><button onclick="editFlight('${doc.id}')" style="background:var(--accent); border:none; border-radius:1rem; padding:4px 8px;">âï¸</button> ${del}</td></tr>`;
            });
        });
    }
    async function editFlight(id) {
        let doc = await db.collection("flights_cloud").doc(id).get();
        let d = doc.data();
        activeFlight = { flight: d.flight, reg: d.reg, type: d.type, airline: d.airline, arrTime: d.arrTime||"", depTime: d.depTime||"" };
        editingDocId = id;
        attachments = {};
        allItems.forEach(n => { let sid = cleanId(n); if(d.items && d.items[n] && d.items[n].attachments) attachments[sid] = d.items[n].attachments; });
        document.getElementById('checklistArea').style.display = 'block';
        buildChecklist();
        setTimeout(() => {
            allItems.forEach(n => {
                let sid = cleanId(n);
                if(d.items && d.items[n]) {
